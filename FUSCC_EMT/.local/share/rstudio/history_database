1774784764871:get_cor_stats <- function(x, y) {
1774784764873:# Remove NA values
1774784764874:idx <- !is.na(x) & !is.na(y)
1774784764875:x <- x[idx]
1774784764876:y <- y[idx]
1774784764878:# Calculate correlation
1774784764880:cor_test <- cor.test(x, y, method = "pearson")
1774784764881:r_squared <- cor_test$estimate^2
1774784764882:p_value <- cor_test$p.value
1774784764884:return(list(r_squared = r_squared, p_value = p_value))
1774784764885:}
