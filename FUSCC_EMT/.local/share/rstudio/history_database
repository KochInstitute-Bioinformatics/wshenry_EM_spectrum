1774553639132:get_cor_stats <- function(x, y) {
1774553639135:# Remove NA values
1774553639138:idx <- !is.na(x) & !is.na(y)
1774553639140:x <- x[idx]
1774553639143:y <- y[idx]
1774553639148:# Calculate correlation
1774553639209:cor_test <- cor.test(x, y, method = "pearson")
1774553639211:r_squared <- cor_test$estimate^2
1774553639216:p_value <- cor_test$p.value
1774553639221:return(list(r_squared = r_squared, p_value = p_value))
1774553639224:}
