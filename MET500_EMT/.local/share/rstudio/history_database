1774552789781:get_cor_stats <- function(x, y) {
1774552789784:# Remove NA values
1774552789787:idx <- !is.na(x) & !is.na(y)
1774552789789:x <- x[idx]
1774552789792:y <- y[idx]
1774552789855:# Calculate correlation
1774552789858:cor_test <- cor.test(x, y, method = "pearson")
1774552789860:r_squared <- cor_test$estimate^2
1774552789863:p_value <- cor_test$p.value
1774552789868:return(list(r_squared = r_squared, p_value = p_value))
1774552789870:}
